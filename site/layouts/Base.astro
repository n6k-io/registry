---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      if (localStorage.getItem("theme") === "light") {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="min-h-screen bg-white font-sans text-neutral-900 dark:bg-neutral-950 dark:text-neutral-200"
  >
    <header class="border-b border-neutral-200 dark:border-neutral-800">
      <div
        class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4"
      >
        <a href="/" class="text-lg font-semibold hover:opacity-80">@n6k.io/ui</a
        >
        <div class="flex items-center gap-4">
          <button
            id="theme-toggle"
            class="rounded-md p-2 text-neutral-500 hover:bg-neutral-100 dark:text-neutral-400 dark:hover:bg-neutral-800"
            aria-label="Toggle theme"
          >
            <svg
              id="icon-sun"
              class="hidden h-5 w-5 dark:block"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="5"></circle><path
                d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
              ></path>
            </svg>
            <svg
              id="icon-moon"
              class="block h-5 w-5 dark:hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>
          <a
            href="https://github.com/n6k-io/registry"
            target="_blank"
            rel="noopener"
            class="text-sm text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-200"
          >
            GitHub &rarr;
          </a>
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-3xl px-6 py-8">
      <slot />
    </main>
    <script is:inline>
      document.getElementById("theme-toggle").addEventListener("click", () => {
        const html = document.documentElement;
        html.classList.toggle("dark");
        localStorage.setItem(
          "theme",
          html.classList.contains("dark") ? "dark" : "light",
        );
      });
    </script>
  </body>
</html>
