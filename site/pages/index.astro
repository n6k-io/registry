---
import Base from "../layouts/Base.astro";
import { readFileSync } from "fs";
import { join } from "path";

const registry = JSON.parse(
  readFileSync(join(process.cwd(), "public", "r", "registry.json"), "utf-8"),
);

const items = registry.items ?? [];

function getCategory(item: { type?: string; name: string }): string {
  if (item.type === "registry:lib") return "lib";
  if (
    item.name.startsWith("n6k-") &&
    (item.name.includes("chart") || item.name.includes("histogram"))
  )
    return "charts";
  if (
    ["n6k-page", "n6k-section", "n6k-grid", "n6k-columns"].includes(item.name)
  )
    return "layout";
  return "ui";
}

const categorized = items.map((item: { type?: string; name: string; title?: string; description?: string }) => ({
  ...item,
  category: getCategory(item),
}));
---

<Base title={registry.name}>
  <p class="mb-6 text-sm text-neutral-500 dark:text-neutral-500">
    A component registry for data visualization & UI
  </p>

  <section
    class="mb-8 rounded-lg border border-neutral-200 p-4 dark:border-neutral-800"
  >
    <h2
      class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600"
    >
      Setup
    </h2>
    <p class="mb-3 text-sm text-neutral-600 dark:text-neutral-400">
      Add the registry to your <code
        class="rounded border border-neutral-200 bg-neutral-50 px-1.5 py-0.5 text-xs dark:border-neutral-800 dark:bg-neutral-900"
        >components.json</code>
    </p>
    <div class="group relative">
      <pre
        class="overflow-x-auto rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300"><code id="setup-cmd">{`"registries": {\n  "@n6k": "https://n6k-io.github.io/registry/r/{name}.json"\n}`}</code></pre>
      <button
        id="setup-copy-btn"
        class="absolute top-2 right-2 rounded-md bg-neutral-200 p-1.5 text-neutral-500 opacity-0 group-hover:opacity-100 hover:text-neutral-900 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200"
        aria-label="Copy setup config"
      >
        <svg
          class="setup-copy-icon h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path
            d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
        </svg>
        <svg
          class="setup-check-icon hidden h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
    <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400">
      Then install components with:
    </p>
    <pre
      class="mt-2 overflow-x-auto rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300"><code>bunx shadcn@latest add @n6k/&lt;component&gt;</code></pre>
  </section>

  <input
    id="search"
    type="text"
    placeholder="Search components..."
    class="mb-4 w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-2 text-sm text-neutral-900 placeholder-neutral-400 outline-none focus:ring-2 focus:ring-neutral-300 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-200 dark:placeholder-neutral-600 dark:focus:ring-neutral-700"
  />

  <div id="filters" class="mb-6 flex gap-2 text-sm">
    <button
      data-filter="all"
      class="filter-btn rounded-full border border-neutral-300 bg-neutral-900 px-3 py-1 text-white dark:border-neutral-700 dark:bg-neutral-100 dark:text-neutral-900"
      >All</button
    >
    <button
      data-filter="ui"
      class="filter-btn rounded-full border border-neutral-300 px-3 py-1 text-neutral-600 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-400 dark:hover:bg-neutral-800"
      >UI</button
    >
    <button
      data-filter="charts"
      class="filter-btn rounded-full border border-neutral-300 px-3 py-1 text-neutral-600 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-400 dark:hover:bg-neutral-800"
      >Charts</button
    >
    <button
      data-filter="layout"
      class="filter-btn rounded-full border border-neutral-300 px-3 py-1 text-neutral-600 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-400 dark:hover:bg-neutral-800"
      >Layout</button
    >
    <button
      data-filter="lib"
      class="filter-btn rounded-full border border-neutral-300 px-3 py-1 text-neutral-600 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-400 dark:hover:bg-neutral-800"
      >Lib</button
    >
  </div>

  <div
    id="component-list"
    class="divide-y divide-neutral-200 rounded-lg border border-neutral-200 dark:divide-neutral-800 dark:border-neutral-800"
  >
    {
      categorized.map((item: { name: string; title?: string; description?: string; category: string }) => (
        <a
          href={`/component/${item.name}`}
          class="component-row flex items-center justify-between px-4 py-3 first:rounded-t-lg last:rounded-b-lg hover:bg-neutral-50 dark:hover:bg-neutral-900"
          data-category={item.category}
          data-name={item.name.toLowerCase()}
          data-title={(item.title || item.name).toLowerCase()}
          data-description={(item.description || "").toLowerCase()}
        >
          <div class="min-w-0">
            <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200">
              {item.title || item.name}
            </span>
            <span class="ml-3 truncate text-sm text-neutral-400 dark:text-neutral-500">
              {item.description}
            </span>
          </div>
          <svg
            class="ml-4 h-4 w-4 shrink-0 text-neutral-400 dark:text-neutral-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))
    }
  </div>

  <p
    id="count"
    class="mt-3 text-right text-xs text-neutral-400 dark:text-neutral-600"
  >
    {items.length} components
  </p>

  <script is:inline>
    const search = document.getElementById("search");
    const rows = document.querySelectorAll(".component-row");
    const filterBtns = document.querySelectorAll(".filter-btn");
    const countEl = document.getElementById("count");
    let activeFilter = "all";

    function applyFilters() {
      const query = search.value.toLowerCase();
      let visible = 0;
      rows.forEach((row) => {
        const matchesFilter =
          activeFilter === "all" || row.dataset.category === activeFilter;
        const matchesSearch =
          !query ||
          row.dataset.name.includes(query) ||
          row.dataset.title.includes(query) ||
          row.dataset.description.includes(query);
        const show = matchesFilter && matchesSearch;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      });
      countEl.textContent = visible + " component" + (visible !== 1 ? "s" : "");
    }

    search.addEventListener("input", applyFilters);

    document.getElementById("setup-copy-btn").addEventListener("click", () => {
      const cmd = document.getElementById("setup-cmd").textContent;
      navigator.clipboard.writeText(cmd).then(() => {
        document.querySelector(".setup-copy-icon").classList.add("hidden");
        document.querySelector(".setup-check-icon").classList.remove("hidden");
        setTimeout(() => {
          document.querySelector(".setup-copy-icon").classList.remove("hidden");
          document.querySelector(".setup-check-icon").classList.add("hidden");
        }, 2000);
      });
    });

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeFilter = btn.dataset.filter;
        filterBtns.forEach((b) => {
          if (b === btn) {
            b.classList.add(
              "bg-neutral-900",
              "text-white",
              "dark:bg-neutral-100",
              "dark:text-neutral-900",
            );
            b.classList.remove("text-neutral-600", "dark:text-neutral-400");
          } else {
            b.classList.remove(
              "bg-neutral-900",
              "text-white",
              "dark:bg-neutral-100",
              "dark:text-neutral-900",
            );
            b.classList.add("text-neutral-600", "dark:text-neutral-400");
          }
        });
        applyFilters();
      });
    });
  </script>
</Base>
