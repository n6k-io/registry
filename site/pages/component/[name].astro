---
import Base from "../../layouts/Base.astro";
import { CodeViewer } from "../../components/code-viewer";
import { SourceViewer } from "../../components/source-viewer";
import { ExampleRenderer } from "../../components/example-renderer";
import { readFileSync, readdirSync, existsSync } from "fs";
import { join, basename } from "path";
import { getHighlighter, highlight } from "../../lib/highlighter";

export function getStaticPaths() {
  const dir = join(process.cwd(), "public", "r");
  const files = readdirSync(dir).filter(
    (f) => f.endsWith(".json") && f !== "registry.json",
  );
  return files.map((f) => ({
    params: { name: f.replace(".json", "") },
  }));
}

const { name } = Astro.params;

const registry = JSON.parse(
  readFileSync(join(process.cwd(), "public", "r", "registry.json"), "utf-8"),
);

const component = JSON.parse(
  readFileSync(join(process.cwd(), "public", "r", `${name}.json`), "utf-8"),
);

const installCmd = `bunx shadcn@latest add @n6k/${name}`;

// Load docs
const docsPath = join(process.cwd(), "public", "docs.json");
const allDocs = existsSync(docsPath)
  ? JSON.parse(readFileSync(docsPath, "utf-8"))
  : {};

type PropDoc = {
  name: string;
  type: string;
  optional: boolean;
  description: string;
};
type ExportDoc = {
  name: string;
  description: string;
  import: string;
  props: PropDoc[];
};
const componentDocs: { exports: ExportDoc[] } | undefined = allDocs[name];

// Load examples
const examplesPath = join(process.cwd(), "examples.json");
const examplesMap = existsSync(examplesPath)
  ? JSON.parse(readFileSync(examplesPath, "utf-8"))
  : {};

type ExampleEntry = { title: string; description?: string; path: string };
const exampleEntries: ExampleEntry[] = examplesMap[name] ?? [];

// Syntax highlighter (singleton)
const highlighter = await getHighlighter();

const examples = exampleEntries.map((entry) => {
  const absPath = join(process.cwd(), entry.path);
  const globPath = entry.path.replace("./examples/", "../../examples/");
  const code = existsSync(absPath) ? readFileSync(absPath, "utf-8") : "";
  return {
    title: entry.title,
    description: entry.description,
    globPath,
    filename: basename(entry.path),
    code,
    html: code ? highlight(highlighter, code) : "",
  };
});

const heroExample = examples[0];
const additionalExamples = examples.slice(1);

// Resolve registry dependency links
const registryDeps: {
  name: string;
  displayName: string;
  href: string | null;
}[] = [];
if (component.registryDependencies) {
  const rDir = join(process.cwd(), "public", "r");
  for (const dep of component.registryDependencies as string[]) {
    const stripped = dep.startsWith("@n6k/") ? dep.slice(5) : dep;
    const hasPage = existsSync(join(rDir, `${stripped}.json`));
    registryDeps.push({
      name: dep,
      displayName: stripped,
      href: hasPage ? `/component/${stripped}` : null,
    });
  }
}

// Source files — highlight for the sheet
const sourceFiles = (component.files ?? [])
  .filter((f: { content?: string; path: string }) => f.content)
  .map((f: { content: string; path: string }) => {
    const lang = f.path.endsWith(".ts")
      ? ("typescript" as const)
      : ("tsx" as const);
    return {
      path: f.path,
      code: f.content,
      html: highlight(highlighter, f.content, lang),
    };
  });
---

<Base title={`${component.title || name} - ${registry.name}`}>
  <a
    href="/"
    class="mb-6 inline-flex items-center gap-1 text-sm text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-200"
  >
    <svg
      class="h-4 w-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M15 19l-7-7 7-7"></path>
    </svg>
    Back
  </a>

  <div class="mb-6 flex items-start justify-between">
    <div>
      <h1 class="mb-1 text-2xl font-semibold">{component.title || name}</h1>
      <p class="text-sm text-neutral-500 dark:text-neutral-500">
        {component.description}
      </p>
    </div>
    {sourceFiles.length > 0 && <SourceViewer files={sourceFiles} client:load />}
  </div>

  {
    heroExample && (
      <section class="mb-8">
        <div class="overflow-hidden rounded-lg border border-neutral-200 dark:border-neutral-800">
          <div class="bg-neutral-50 dark:bg-neutral-900">
            <ExampleRenderer examplePath={heroExample.globPath} client:load />
          </div>
          <div class="flex items-center justify-end border-t border-neutral-200 bg-white px-4 py-2 dark:border-neutral-800 dark:bg-neutral-950">
            <CodeViewer
              code={heroExample.code}
              html={heroExample.html}
              filename={heroExample.filename}
              client:load
            />
          </div>
        </div>
      </section>
    )
  }

  {
    componentDocs && componentDocs.exports.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600">
          Usage
        </h2>
        <div class="space-y-4">
          {componentDocs.exports.map((exp) => (
            <div>
              <div class="mb-1 flex items-center gap-2">
                <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200">
                  {exp.name}
                </span>
                {exp.description && (
                  <span class="text-xs text-neutral-500 dark:text-neutral-400">
                    {exp.description}
                  </span>
                )}
              </div>
              <div class="group relative">
                <pre class="overflow-x-auto rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300">
                  <code class="copy-content">{exp.import}</code>
                </pre>
                <button
                  class="copy-btn absolute top-2 right-2 rounded-md bg-neutral-200 p-1.5 text-neutral-500 opacity-0 group-hover:opacity-100 hover:text-neutral-900 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200"
                  aria-label={`Copy ${exp.name} import`}
                >
                  <svg
                    class="copy-icon h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                    <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                  </svg>
                  <svg
                    class="check-icon hidden h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    componentDocs && componentDocs.exports.some((e) => e.props.length > 0) && (
      <section class="mb-8">
        <h2 class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600">
          Props
        </h2>
        <div class="space-y-6">
          {componentDocs.exports
            .filter((e) => e.props.length > 0)
            .map((exp) => (
              <div>
                {componentDocs.exports.filter((e) => e.props.length > 0)
                  .length > 1 && (
                  <h3 class="mb-2 text-sm font-medium text-neutral-900 dark:text-neutral-200">
                    {exp.name}
                  </h3>
                )}
                <div class="overflow-hidden rounded-lg border border-neutral-200 dark:border-neutral-800">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-neutral-200 bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900">
                        <th class="px-4 py-2 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400">
                          Name
                        </th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400">
                          Type
                        </th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400">
                          Required
                        </th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400">
                          Description
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      {exp.props.map((prop: PropDoc) => (
                        <tr class="border-b border-neutral-200 last:border-0 dark:border-neutral-800">
                          <td class="px-4 py-2 font-mono text-xs text-neutral-900 dark:text-neutral-200">
                            {prop.name}
                          </td>
                          <td class="px-4 py-2 font-mono text-xs text-neutral-500 dark:text-neutral-400">
                            {prop.type}
                          </td>
                          <td class="px-4 py-2 text-xs text-neutral-500 dark:text-neutral-400">
                            {prop.optional ? "No" : "Yes"}
                          </td>
                          <td class="px-4 py-2 text-xs text-neutral-500 dark:text-neutral-400">
                            {prop.description}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
        </div>
      </section>
    )
  }

  <section class="mb-8">
    <h2
      class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600"
    >
      Install
    </h2>
    <div class="group relative">
      <pre
        class="overflow-x-auto rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-800 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300"><code class="copy-content">{installCmd}</code></pre>
      <button
        class="copy-btn absolute top-2 right-2 rounded-md bg-neutral-200 p-1.5 text-neutral-500 opacity-0 group-hover:opacity-100 hover:text-neutral-900 dark:bg-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200"
        aria-label="Copy install command"
      >
        <svg
          class="copy-icon h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path
            d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
        </svg>
        <svg
          class="check-icon hidden h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
  </section>

  {
    component.dependencies?.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600">
          Dependencies
        </h2>
        <div class="flex flex-wrap gap-2">
          {component.dependencies.map((dep: string) => (
            <span class="rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1 text-xs text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
              {dep}
            </span>
          ))}
        </div>
      </section>
    )
  }

  {
    registryDeps.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600">
          Registry Dependencies
        </h2>
        <div class="flex flex-wrap gap-2">
          {registryDeps.map((dep) =>
            dep.href ? (
              <a
                href={dep.href}
                class="rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1 text-xs text-neutral-600 hover:border-neutral-400 hover:text-neutral-900 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-neutral-600 dark:hover:text-neutral-200"
              >
                {dep.displayName}
              </a>
            ) : (
              <span class="rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1 text-xs text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
                {dep.displayName}
              </span>
            ),
          )}
        </div>
      </section>
    )
  }

  {
    additionalExamples.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 text-xs font-medium tracking-wider text-neutral-400 uppercase dark:text-neutral-600">
          Examples
        </h2>
        <div class="space-y-6">
          {additionalExamples.map(
            (ex: {
              title: string;
              description?: string;
              globPath: string;
              filename: string;
              code: string;
              html: string;
            }) => (
              <div>
                <h3 class="mb-1 text-sm font-medium text-neutral-900 dark:text-neutral-200">
                  {ex.title}
                </h3>
                {ex.description && (
                  <p class="mb-3 text-sm text-neutral-500 dark:text-neutral-400">
                    {ex.description}
                  </p>
                )}
                <div class="overflow-hidden rounded-lg border border-neutral-200 dark:border-neutral-800">
                  <div class="bg-neutral-50 dark:bg-neutral-900">
                    <ExampleRenderer examplePath={ex.globPath} client:load />
                  </div>
                  <div class="flex items-center justify-end border-t border-neutral-200 bg-white px-4 py-2 dark:border-neutral-800 dark:bg-neutral-950">
                    <CodeViewer
                      code={ex.code}
                      html={ex.html}
                      filename={ex.filename}
                      client:load
                    />
                  </div>
                </div>
              </div>
            ),
          )}
        </div>
      </section>
    )
  }

  <script is:inline>
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const container = btn.closest(".relative, .rounded-lg");
        const content = container?.querySelector(".copy-content");
        if (!content) return;
        navigator.clipboard.writeText(content.textContent || "").then(() => {
          const copyIcon = btn.querySelector(".copy-icon");
          const checkIcon = btn.querySelector(".check-icon");
          copyIcon?.classList.add("hidden");
          checkIcon?.classList.remove("hidden");
          setTimeout(() => {
            copyIcon?.classList.remove("hidden");
            checkIcon?.classList.add("hidden");
          }, 2000);
        });
      });
    });
  </script>
</Base>
