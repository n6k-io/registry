---
import Base from "../../layouts/Base.astro";
import { CodeViewer } from "../../components/code-viewer";
import { SourceViewer } from "../../components/source-viewer";
import { ExampleRenderer } from "../../components/example-renderer";
import { readFileSync, readdirSync, existsSync } from "fs";
import { join, basename } from "path";
import { getHighlighter, highlight } from "../../lib/highlighter";

export function getStaticPaths() {
  const dir = join(process.cwd(), "public", "r");
  const files = readdirSync(dir).filter(
    (f) => f.endsWith(".json") && f !== "registry.json"
  );
  return files.map((f) => ({
    params: { name: f.replace(".json", "") },
  }));
}

const { name } = Astro.params;

const registry = JSON.parse(
  readFileSync(join(process.cwd(), "public", "r", "registry.json"), "utf-8")
);

const component = JSON.parse(
  readFileSync(join(process.cwd(), "public", "r", `${name}.json`), "utf-8")
);

const installCmd = `bunx shadcn@latest add @n6k/${name}`;

// Load docs
const docsPath = join(process.cwd(), "public", "docs.json");
const allDocs = existsSync(docsPath)
  ? JSON.parse(readFileSync(docsPath, "utf-8"))
  : {};

type PropDoc = { name: string; type: string; optional: boolean; description: string };
type ExportDoc = { name: string; description: string; import: string; props: PropDoc[] };
const componentDocs: { exports: ExportDoc[] } | undefined = allDocs[name];

// Load examples
const examplesPath = join(process.cwd(), "examples.json");
const examplesMap = existsSync(examplesPath)
  ? JSON.parse(readFileSync(examplesPath, "utf-8"))
  : {};

type ExampleEntry = { title: string; description?: string; path: string };
const exampleEntries: ExampleEntry[] = examplesMap[name] ?? [];

// Syntax highlighter (singleton)
const highlighter = await getHighlighter();

const examples = exampleEntries.map((entry) => {
  const absPath = join(process.cwd(), entry.path);
  const globPath = entry.path.replace("./examples/", "../../examples/");
  const code = existsSync(absPath) ? readFileSync(absPath, "utf-8") : "";
  return {
    title: entry.title,
    description: entry.description,
    globPath,
    filename: basename(entry.path),
    code,
    html: code ? highlight(highlighter, code) : "",
  };
});

const heroExample = examples[0];
const additionalExamples = examples.slice(1);

// Resolve registry dependency links
const registryDeps: { name: string; displayName: string; href: string | null }[] = [];
if (component.registryDependencies) {
  const rDir = join(process.cwd(), "public", "r");
  for (const dep of component.registryDependencies as string[]) {
    const stripped = dep.startsWith("@n6k/") ? dep.slice(5) : dep;
    const hasPage = existsSync(join(rDir, `${stripped}.json`));
    registryDeps.push({
      name: dep,
      displayName: stripped,
      href: hasPage ? `/component/${stripped}` : null,
    });
  }
}

// Source files — highlight for the sheet
const sourceFiles = (component.files ?? [])
  .filter((f: any) => f.content)
  .map((f: any) => {
    const lang = f.path.endsWith(".ts") ? "typescript" as const : "tsx" as const;
    return {
      path: f.path,
      code: f.content,
      html: highlight(highlighter, f.content, lang),
    };
  });
---

<Base title={`${component.title || name} - ${registry.name}`}>
  <a
    href="/"
    class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-200 inline-flex items-center gap-1 mb-6"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M15 19l-7-7 7-7" />
    </svg>
    Back
  </a>

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold mb-1">{component.title || name}</h1>
      <p class="text-neutral-500 dark:text-neutral-500 text-sm">{component.description}</p>
    </div>
    {sourceFiles.length > 0 && (
      <SourceViewer files={sourceFiles} client:load />
    )}
  </div>

  {heroExample && (
    <section class="mb-8">
      <div class="rounded-lg border border-neutral-200 dark:border-neutral-800 overflow-hidden">
        <div class="bg-neutral-50 dark:bg-neutral-900">
          <ExampleRenderer examplePath={heroExample.globPath} client:load />
        </div>
        <div class="flex items-center justify-end px-4 py-2 border-t border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-950">
          <CodeViewer code={heroExample.code} html={heroExample.html} filename={heroExample.filename} client:load />
        </div>
      </div>
    </section>
  )}

  {componentDocs && componentDocs.exports.length > 0 && (
    <section class="mb-8">
      <h2 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-3">Usage</h2>
      <div class="space-y-4">
        {componentDocs.exports.map((exp) => (
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-sm font-medium text-neutral-900 dark:text-neutral-200">{exp.name}</span>
              {exp.description && (
                <span class="text-xs text-neutral-500 dark:text-neutral-400">{exp.description}</span>
              )}
            </div>
            <div class="relative group">
              <pre class="bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-lg px-4 py-3 text-sm text-neutral-800 dark:text-neutral-300 overflow-x-auto"><code class="copy-content">{exp.import}</code></pre>
              <button
                class="copy-btn absolute top-2 right-2 p-1.5 rounded-md bg-neutral-200 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 opacity-0 group-hover:opacity-100 hover:text-neutral-900 dark:hover:text-neutral-200"
                aria-label={`Copy ${exp.name} import`}
              >
                <svg class="copy-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
                <svg class="check-icon w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {componentDocs && componentDocs.exports.some((e) => e.props.length > 0) && (
    <section class="mb-8">
      <h2 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-3">Props</h2>
      <div class="space-y-6">
        {componentDocs.exports.filter((e) => e.props.length > 0).map((exp) => (
          <div>
            {componentDocs.exports.filter((e) => e.props.length > 0).length > 1 && (
              <h3 class="text-sm font-medium text-neutral-900 dark:text-neutral-200 mb-2">{exp.name}</h3>
            )}
            <div class="rounded-lg border border-neutral-200 dark:border-neutral-800 overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900">
                    <th class="text-left px-4 py-2 text-xs font-medium text-neutral-500 dark:text-neutral-400">Name</th>
                    <th class="text-left px-4 py-2 text-xs font-medium text-neutral-500 dark:text-neutral-400">Type</th>
                    <th class="text-left px-4 py-2 text-xs font-medium text-neutral-500 dark:text-neutral-400">Required</th>
                    <th class="text-left px-4 py-2 text-xs font-medium text-neutral-500 dark:text-neutral-400">Description</th>
                  </tr>
                </thead>
                <tbody>
                  {exp.props.map((prop: PropDoc) => (
                    <tr class="border-b border-neutral-200 dark:border-neutral-800 last:border-0">
                      <td class="px-4 py-2 font-mono text-xs text-neutral-900 dark:text-neutral-200">{prop.name}</td>
                      <td class="px-4 py-2 font-mono text-xs text-neutral-500 dark:text-neutral-400">{prop.type}</td>
                      <td class="px-4 py-2 text-xs text-neutral-500 dark:text-neutral-400">{prop.optional ? "No" : "Yes"}</td>
                      <td class="px-4 py-2 text-xs text-neutral-500 dark:text-neutral-400">{prop.description}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="mb-8">
    <h2 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-3">Install</h2>
    <div class="relative group">
      <pre class="bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-lg px-4 py-3 text-sm text-neutral-800 dark:text-neutral-300 overflow-x-auto"><code class="copy-content">{installCmd}</code></pre>
      <button
        class="copy-btn absolute top-2 right-2 p-1.5 rounded-md bg-neutral-200 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 opacity-0 group-hover:opacity-100 hover:text-neutral-900 dark:hover:text-neutral-200"
        aria-label="Copy install command"
      >
        <svg class="copy-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
        </svg>
        <svg class="check-icon w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </button>
    </div>
  </section>

  {(component.dependencies?.length > 0) && (
    <section class="mb-8">
      <h2 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-3">Dependencies</h2>
      <div class="flex gap-2 flex-wrap">
        {component.dependencies.map((dep: string) => (
          <span class="text-xs px-2.5 py-1 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400">
            {dep}
          </span>
        ))}
      </div>
    </section>
  )}

  {registryDeps.length > 0 && (
    <section class="mb-8">
      <h2 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-3">Registry Dependencies</h2>
      <div class="flex gap-2 flex-wrap">
        {registryDeps.map((dep) => (
          dep.href ? (
            <a
              href={dep.href}
              class="text-xs px-2.5 py-1 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-200 hover:border-neutral-400 dark:hover:border-neutral-600"
            >
              {dep.displayName}
            </a>
          ) : (
            <span class="text-xs px-2.5 py-1 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400">
              {dep.displayName}
            </span>
          )
        ))}
      </div>
    </section>
  )}

  {additionalExamples.length > 0 && (
    <section class="mb-8">
      <h2 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-3">Examples</h2>
      <div class="space-y-6">
        {additionalExamples.map((ex: any) => (
          <div>
            <h3 class="text-sm font-medium text-neutral-900 dark:text-neutral-200 mb-1">{ex.title}</h3>
            {ex.description && (
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-3">{ex.description}</p>
            )}
            <div class="rounded-lg border border-neutral-200 dark:border-neutral-800 overflow-hidden">
              <div class="bg-neutral-50 dark:bg-neutral-900">
                <ExampleRenderer examplePath={ex.globPath} client:load />
              </div>
              <div class="flex items-center justify-end px-4 py-2 border-t border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-950">
                <CodeViewer code={ex.code} html={ex.html} filename={ex.filename} client:load />
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <script is:inline>
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const container = btn.closest(".relative, .rounded-lg");
        const content = container?.querySelector(".copy-content");
        if (!content) return;
        navigator.clipboard.writeText(content.textContent || "").then(() => {
          const copyIcon = btn.querySelector(".copy-icon");
          const checkIcon = btn.querySelector(".check-icon");
          copyIcon?.classList.add("hidden");
          checkIcon?.classList.remove("hidden");
          setTimeout(() => {
            copyIcon?.classList.remove("hidden");
            checkIcon?.classList.add("hidden");
          }, 2000);
        });
      });
    });
  </script>
</Base>
